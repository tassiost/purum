<%- include('partials/header') %>

<section class="about-section">
  <div class="about-grid">
    <div class="about-bio">
      <div>
        <h1 class="headline-lg" style="margin-bottom: 24px;">BIOGRAPHY</h1>
        <p class="body-lg" style="line-height: 32px; color: var(--on-background);">
          <%= settings.biography %>
        </p>
      </div>

      <div>
        <h2 class="label-md" style="margin-bottom: 16px; color: var(--text-muted);">ARTIST STATEMENT</h2>
        <p class="body-md text-muted" style="line-height: 28px; white-space: pre-line; border-left: 2px solid var(--border-muted); padding-left: 24px;">
          "<%= settings.artistStatement %>"
        </p>
      </div>

      <div style="border-top: 1px solid var(--border-muted); padding-top: 48px; margin-top: 24px;" id="contact">
        <h2 class="headline-lg" style="margin-bottom: 32px;">CONTACT & INQUIRIES</h2>

        <% if (typeof successMsg !== 'undefined' && successMsg) { %>
          <div class="alert alert-success">
            <%= successMsg %>
          </div>
        <% } %>
        <% if (typeof errorMsg !== 'undefined' && errorMsg) { %>
          <div class="alert alert-danger">
            <%= errorMsg %>
          </div>
        <% } %>

        <form action="/contact" method="POST" style="max-width: 600px;">
          <div class="form-group">
            <label for="name">NAME</label>
            <input type="text" id="name" name="name" required placeholder="YOUR NAME">
          </div>
          <div class="form-group">
            <label for="email">EMAIL ADDRESS</label>
            <input type="email" id="email" name="email" required placeholder="YOUR.EMAIL@DOMAIN.COM">
          </div>
          <div class="form-group">
            <label for="subject">SUBJECT</label>
            <input type="text" id="subject" name="subject" required placeholder="INQUIRY SUBJECT">
          </div>
          <div class="form-group">
            <label for="message">MESSAGE</label>
            <textarea id="message" name="message" required placeholder="TYPE MESSAGE HERE..."></textarea>
          </div>
          <button type="submit" class="btn">SEND MESSAGE</button>
        </form>
      </div>
    </div>
    
    <div class="about-visual">
      <img src="<%= settings.profilePicture %>" alt="<%= settings.artistName %>">
    </div>
  </div>
</section>

<%- include('partials/footer') %>
