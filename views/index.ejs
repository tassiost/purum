    </div>
    <div class="flex gap-margin-mobile">
      <a class="font-label-sm text-label-sm text-outline hover:text-primary transition-colors" href="#">PRIVACY</a>
      <a class="font-label-sm text-label-sm text-outline hover:text-primary transition-colors" href="mailto:<%= settings.contactEmail %>">CONTACT</a>
    </div>
    <div class="flex gap-stack-md mt-stack-lg md:mt-0">
      <a href="#" onclick="shareWebsite(event)" class="w-10 h-10 border border-outline-variant flex items-center justify-center hover:bg-primary hover:text-on-primary transition-none" title="SHARE">
        <span class="material-symbols-outlined text-[18px]">share</span>
      </a>
      <% if (settings.github) { %>
        <a class="w-10 h-10 border border-outline-variant flex items-center justify-center hover:bg-primary hover:text-on-primary transition-none" href="https://github.com/<%= settings.github %>" target="_blank" rel="noopener noreferrer">
          <span class="material-symbols-outlined text-[18px]">public</span>
        </a>
      <% } %>
    </div>
  </footer>

  <!-- Fixed Technical Telemetry (Brutalist UX Accent) -->
  <div class="fixed bottom-4 left-6 md:left-16 font-label-sm text-[10px] text-outline z-50 pointer-events-none hidden lg:block select-none opacity-60 uppercase tracking-widest">
    GRID_NODE: X:<span id="coord-x">0000</span>_Y:<span id="coord-y">0000</span> // TEMP: <span id="telemetry-bpm">142</span>_BPM
  </div>

  <!-- Cookie Consent Placeholder -->
  <div class="fixed bottom-margin-mobile right-margin-mobile z-[100] max-w-xs bg-surface-container-highest border border-outline-variant p-stack-md shadow-2xl transition-all duration-500" id="cookie-consent">
    <p class="font-body-md text-body-md text-on-surface mb-stack-md">PURUM uses cookies to ensure structural integrity and experience tracking.</p>
    <button class="w-full bg-primary text-on-primary py-stack-sm font-label-md text-label-md uppercase" onclick="this.closest('#cookie-consent').style.display='none'">
      ACKNOWLEDGE
    </button>
  </div>

  <script>
    // Atmospheric effects
    window.addEventListener('load', () => {
      setTimeout(() => {
        const consent = document.getElementById('cookie-consent');
        if (consent) {
          consent.classList.remove('opacity-0', 'translate-y-4');
        }
      }, 2000);

      // Subtle parallax on images
      window.addEventListener('scroll', () => {
        const scrolled = window.pageYOffset;
        const images = document.querySelectorAll('img');
        images.forEach(img => {
          const speed = 0.05;
          if(img.closest('.asymmetric-image-container')) {
            img.style.transform = `translateY(${scrolled * speed}px)`;
          }
        });
      });
    });

    // Instant click simulation
    document.querySelectorAll('a, button').forEach(el => {
      el.addEventListener('mousedown', () => {
        el.style.opacity = '0.7';
      });
      el.addEventListener('mouseup', () => {
        el.style.opacity = '1';
      });
    });

    // Liquid Displacement Shader variables
    let currentScale = 0;
    let targetScale = 0;
    const displacementMap = document.querySelector('#spotlight-shader feDisplacementMap');

    function animateShader() {
      currentScale += (targetScale - currentScale) * 0.15;
      if (displacementMap) {
        displacementMap.setAttribute('scale', currentScale.toFixed(2));
      }
      requestAnimationFrame(animateShader);
    }
    animateShader();

    // Spotlight Hover Mousemove Reveal with displacement shader mapping
    document.querySelectorAll('.spotlight-container').forEach(container => {
      const colorImg = container.querySelector('.color-layer');
      if (!colorImg) return;

      container.addEventListener('mousemove', (e) => {
        const rect = container.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        colorImg.style.clipPath = `circle(110px at ${x}px ${y}px)`;
        
        // Dynamic position of the radar target reticle
        const sight = container.querySelector('.scan-sight');
        if (sight) {
          sight.style.left = `${x}px`;
          sight.style.top = `${y}px`;
        }
        targetScale = 25;
      });

      container.addEventListener('mouseleave', () => {
        colorImg.style.clipPath = 'circle(0px at 0px 0px)';
        targetScale = 0;
      });
    });

    // Live Technical Telemetry Coordinates Tracker
    const xCoord = document.getElementById('coord-x');
    const yCoord = document.getElementById('coord-y');
    const bpmCoord = document.getElementById('telemetry-bpm');
    
    if (xCoord && yCoord) {
      window.addEventListener('mousemove', (e) => {
        xCoord.innerText = e.clientX.toString().padStart(4, '0');
        yCoord.innerText = e.clientY.toString().padStart(4, '0');
        
        if (bpmCoord) {
          const bpmVal = 135 + Math.round((e.clientX + e.clientY) % 15);
          bpmCoord.innerText = bpmVal.toString();
        }
      });
    }

    // Mobile menu toggle
    function toggleMobileMenu() {
      const menu = document.getElementById('mobile-menu');
      if (menu) {
        menu.classList.toggle('hidden');
      }
    }

    // Share Website handler
    function shareWebsite(e) {
      e.preventDefault();
      if (navigator.share) {
        navigator.share({
          title: 'PURUM | BERN // SWITZERLAND',
          text: 'Check out PURUM - Groove-focused techno, house and chaotic energy.',
          url: window.location.href
        }).catch(console.error);
      } else {
        navigator.clipboard.writeText(window.location.href).then(() => {
          alert('WEBSITE LINK COPIED TO CLIPBOARD');
        }).catch(err => {
          console.error('Could not copy text: ', err);
        });
      }
    }

    // Bespoke Brutalist Waveform Audio Player Logic
    document.addEventListener('DOMContentLoaded', () => {
      const audio = document.getElementById('hero-audio');
      const playBtn = document.getElementById('player-play-btn');
      const playIcon = document.getElementById('player-play-icon');
      const waveform = document.getElementById('waveform-container');
      const bgIframe = document.querySelector('iframe[src*="visualizer"]');
      const timeCurrent = document.getElementById('player-time-current');
      const playhead = document.getElementById('player-playhead');
      
      if (!audio || !playBtn || !waveform) return;

      // 1. Generate 55 static wave bars mimicking a real techno waveform
      const heights = [
        15, 25, 30, 45, 35, 20, 10, 25, 40, 50, 60, 45, 30, 15, 20, 35, 45, 55, 65, 50, 
        40, 30, 20, 10, 25, 35, 45, 50, 40, 30, 15, 25, 30, 40, 55, 65, 75, 70, 55, 
        45, 35, 25, 10, 20, 35, 50, 60, 55, 40, 30, 15, 20, 35, 50, 40
      ];
      for (let i = 0; i < 55; i++) {
        const bar = document.createElement('div');
        bar.className = 'waveform-bar flex-grow bg-white/20 transition-colors pointer-events-none';
        bar.style.height = `${heights[i]}%`;
        waveform.appendChild(bar);
      }

      // 1.5 Sync Duration when metadata is loaded
      audio.addEventListener('loadedmetadata', () => {
        console.log('Audio metadata loaded. Duration:', audio.duration);
        const totMin = Math.floor(audio.duration / 60);
        const totSec = Math.floor(audio.duration % 60).toString().padStart(2, '0');
        document.getElementById('player-time-total').innerText = `${totMin}:${totSec}`;
      });

      // 2. Play / Pause Control Toggle
      playBtn.addEventListener('click', () => {
        if (audio.paused) {
          // Resume the iframe's Three.js AudioContext from the parent page on user gesture
          try {
            if (bgIframe && bgIframe.contentWindow && bgIframe.contentWindow.THREE && bgIframe.contentWindow.THREE.AudioContext) {
              bgIframe.contentWindow.THREE.AudioContext.getContext().resume();
            }
          } catch (err) {
            console.error('Error resuming iframe AudioContext:', err);
          }

          if (bgIframe && bgIframe.contentWindow) {
            bgIframe.contentWindow.postMessage({ type: 'SC_PLAY' }, '*');
          }
          audio.play();
          playIcon.innerText = 'pause';
        } else {
          audio.pause();
          playIcon.innerText = 'play_arrow';
          if (bgIframe && bgIframe.contentWindow) {
            bgIframe.contentWindow.postMessage({ type: 'SC_PAUSE' }, '*');
          }
        }
      });

      // 3. Audio Time Update (Scrubbing feedback, timecodes & highlight)
      audio.addEventListener('timeupdate', () => {
        if (isNaN(audio.duration) || !isFinite(audio.duration) || audio.duration === 0) return;
        const progress = audio.currentTime / audio.duration;
        const barCount = Math.floor(progress * 55);
        
        // Highlight active waveform bars
        const bars = document.querySelectorAll('.waveform-bar');
        bars.forEach((bar, idx) => {
          if (idx < barCount) {
            bar.style.backgroundColor = '#ffffff'; // Stark white (played)
          } else {
            bar.style.backgroundColor = 'rgba(255, 255, 255, 0.20)'; // Muted grey (unplayed)
          }
        });

        // Update current playhead line position
        if (playhead) {
          playhead.style.left = `${progress * 100}%`;
        }

        // Update current playhead time text (minutes:seconds)
        const curMin = Math.floor(audio.currentTime / 60);
        const curSec = Math.floor(audio.currentTime % 60).toString().padStart(2, '0');
        timeCurrent.innerText = `${curMin}:${curSec}`;
        
        // Move the timecode horizontally to hover over the current playhead bar!
        const offsetPercent = Math.min(progress * 100, 85); // clamp to prevent clipping off-right
        timeCurrent.style.left = `${offsetPercent}%`;
      });

      // 4. Interactive Waveform Scrubbing (seek to click)
      waveform.addEventListener('click', (e) => {
        const rect = waveform.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const percentage = Math.max(0, Math.min(1, x / rect.width));
        
        if (!isNaN(audio.duration)) {
          audio.currentTime = percentage * audio.duration;
        }
      });
      
      // Auto reset play icon on song finish
      audio.addEventListener('ended', () => {
        playIcon.innerText = 'play_arrow';
        if (bgIframe && bgIframe.contentWindow) {
          bgIframe.contentWindow.postMessage({ type: 'SC_PAUSE' }, '*');
        }
        if (playhead) {
          playhead.style.left = '0%';
        }
      });
    });
  </script>
  <!-- Hidden SVG displacement map filter (spotlight liquid shader) -->
  <svg style="position: absolute; width: 0; height: 0; pointer-events: none;" aria-hidden="true">
    <defs>
      <filter id="spotlight-shader">
        <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="2" result="noise" />
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>
</body>
</html>
