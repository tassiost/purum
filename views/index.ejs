              <a href="https://soundcloud.com/purumofficial" target="_blank" class="absolute bottom-1 left-1 font-label-sm text-[8px] text-outline hover:text-primary leading-none bg-black/60 px-1 py-0.5">Privacy policy</a>
            </div>

            <!-- Right: Play & Waveform -->
            <div class="flex-grow flex flex-col justify-between py-1 pr-4">
              <!-- Top Metadata & Social Row -->
              <div class="flex justify-between items-start gap-2">
                <div class="flex items-center gap-3">
                  <!-- Play / Pause Button -->
                  <button id="player-play-btn" class="w-12 h-12 rounded-full bg-white text-black flex items-center justify-center hover:scale-105 transition-transform active:scale-95 cursor-crosshair">
                    <span id="player-play-icon" class="material-symbols-outlined text-[24px] font-bold" style="font-variation-settings: 'FILL' 1, 'wght' 700;">play_arrow</span>
                  </button>
                  <div class="flex flex-col">
                    <a href="https://soundcloud.com/purumofficial" target="_blank" class="font-label-sm text-[11px] text-outline uppercase tracking-wider hover:underline">Purum</a>
                    <h4 class="font-body-md text-[13px] font-bold text-primary tracking-wide leading-tight truncate max-w-[150px] md:max-w-[200px]" id="player-title">Qoala - Mas Que Nada (2013)</h4>
                  </div>
                </div>
                <!-- Social & SC branding -->
                <div class="flex items-center gap-2 text-outline">
                  <a href="https://soundcloud.com/purumofficial" target="_blank" class="hover:text-primary transition-colors cursor-crosshair" title="LIKE"><span class="material-symbols-outlined text-[16px]">favorite</span></a>
                  <a href="https://soundcloud.com/purumofficial/reason" target="_blank" class="hover:text-primary transition-colors cursor-crosshair" title="DOWNLOAD"><span class="material-symbols-outlined text-[16px]">download</span></a>
                  <a href="#" onclick="shareWebsite(event)" class="hover:text-primary transition-colors cursor-crosshair" title="SHARE"><span class="material-symbols-outlined text-[16px]">share</span></a>
                  <a href="https://soundcloud.com/purumofficial" target="_blank" class="ml-2 hover:text-primary transition-colors" title="SOUNDCLOUD">
                    <svg class="h-4 w-auto fill-current" viewBox="0 0 24 24"><path d="M12 12.5a.5.5 0 0 1 .5.5v3a.5.5 0 0 1-1 0v-3a.5.5 0 0 1 .5-.5zm1.5.5a.5.5 0 0 1 1 0v2.5a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 1 0v2a.5.5 0 0 1-1 0zm2 .5a.5.5 0 0 1 1 0v1.5a.5.5 0 0 1-1 0zm2 .5a.5.5 0 0 1 1 0v1a.5.5 0 0 1-1 0zm-8.5-2a.5.5 0 0 0-.5.5v3.5a.5.5 0 0 0 1 0v-3.5a.5.5 0 0 0-.5-.5zm-1.5 1a.5.5 0 0 0-.5.5v2.5a.5.5 0 0 0 1 0v-2.5a.5.5 0 0 0-.5-.5zm-1.5.5a.5.5 0 0 0-.5.5v2a.5.5 0 0 0 1 0v-2a.5.5 0 0 0-.5-.5zm-1.5.5a.5.5 0 0 0-.5.5v1.5a.5.5 0 0 0 1 0v-1.5a.5.5 0 0 0-.5-.5zm-1.5.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 1 0v-1a.5.5 0 0 0-.5-.5zm-1.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 1 0v-1a.5.5 0 0 0-.5-.5zm-1.5-.5a.5.5 0 0 0-.5.5v1.5a.5.5 0 0 0 1 0v-1.5a.5.5 0 0 0-.5-.5zM1.5 13a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 1 0v-1a.5.5 0 0 0-.5-.5z"/></svg>
                  </a>
                </div>
              </div>

              <!-- Mid: Waveform Visualizer -->
              <div class="relative w-full h-[60px] flex items-end gap-[1px] mt-2 cursor-crosshair group" id="waveform-container">
                <!-- Vertical Playhead Line -->
                <div id="player-playhead" class="absolute top-0 bottom-0 w-[2px] bg-white pointer-events-none z-10" style="left: 0%;"></div>
                <!-- Floating current timecode -->
                <div id="player-time-current" class="absolute bottom-[2px] left-0 font-label-sm text-[9px] text-[#808080] pointer-events-none select-none z-20">0:00</div>
                <!-- Total duration badge -->
                <div id="player-time-total" class="absolute bottom-[2px] right-0 font-label-sm text-[9px] text-black bg-white px-1 py-0.5 pointer-events-none select-none font-bold z-20">4:47</div>
              </div>

              <!-- Bottom Row: Plays counts -->
              <div class="flex justify-end items-center text-outline mt-1 text-[10px]">
                <span class="flex items-center gap-1 font-label-sm text-[9px]"><span class="material-symbols-outlined text-[10px]">play_arrow</span> 28</span>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-4">
            <a class="font-label-md text-label-md text-primary tracking-[0.2em] hover:tracking-[0.3em] transition-all duration-300" href="mailto:<%= settings.contactEmail %>">BOOKING: <%= settings.contactEmail.toUpperCase() %> ———</a>
