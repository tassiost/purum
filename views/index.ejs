    <!-- About Section -->
    <section class="px-margin-mobile md:px-margin-desktop py-section-gap border-t border-outline-variant" id="about">
      <h3 class="font-headline-lg text-[28px] sm:text-[32px] md:text-headline-lg uppercase tracking-tight leading-none text-primary font-bold mb-stack-lg">PROJECT_MANIFESTO</h3>
