        <p class="font-body-lg text-body-lg text-on-surface leading-relaxed border-l-2 border-primary pl-6">
          <%= settings.biography %>
        </p>
        <p class="font-body-lg text-body-lg text-secondary leading-relaxed pl-6 lg:pl-0">
          <%= settings.artistStatement %>
        </p>
      </div>
    </section>

    <!-- System Archives (Gallery) -->
    <section class="px-margin-mobile md:px-margin-desktop py-section-gap bg-surface-container-lowest border-t border-b border-outline-variant" id="archives">
      <div class="flex justify-between items-end border-b border-outline-variant pb-stack-md mb-stack-lg">
        <h3 class="font-headline-lg text-[28px] sm:text-[32px] md:text-headline-lg uppercase tracking-tight">SYSTEM ARCHIVES</h3>
        <span class="font-label-md text-label-md text-outline">VINTAGE_CULTURE_SYS_042</span>
      </div>
      <div class="grid grid-cols-2 gap-4 md:grid-cols-3">
        <% artworks.forEach(art => { %>
          <div class="aspect-[2/3] overflow-hidden border border-outline-variant spotlight-container cursor-crosshair relative group">
            <a href="/project/<%= art.id %>" class="block w-full h-full relative">
              <!-- Gray Base Image -->
              <img alt="<%= art.title %>" class="w-full h-full object-cover grayscale brightness-75 transition-all duration-700 pointer-events-none" src="<%= art.imageUrl %>"/>
              <!-- Color Overlay Image -->
              <img alt="<%= art.title %> Color" class="color-layer absolute inset-0 w-full h-full object-cover brightness-100 contrast-100 pointer-events-none" src="<%= art.imageUrl %>" style="clip-path: circle(0px at 0px 0px);"/>
