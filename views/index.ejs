        <h3 class="font-headline-lg text-[28px] sm:text-[32px] md:text-headline-lg uppercase tracking-tight">Label Affiliation</h3>
        <span class="font-label-md text-label-md text-outline">YAKU.RECORDS_SYS</span>
      </div>
      <div class="mt-8">
        <!-- Label Info Card (Centered & Clean) -->
        <div class="max-w-3xl mx-auto border border-outline-variant hover:border-primary transition-colors cursor-crosshair p-stack-lg bg-surface-container-low flex flex-col justify-between min-h-[160px]">
