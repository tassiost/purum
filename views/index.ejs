        </div>
      </div>
      <div class="col-span-12 lg:col-span-6 relative order-1 lg:order-2 h-[60vh] lg:h-[80vh] border border-outline-variant overflow-hidden spotlight-container cursor-crosshair">
        <!-- Gray Base Image -->
        <img alt="<%= settings.artistName %> Portrait" class="w-full h-full object-cover object-top grayscale brightness-90 contrast-110 z-0 relative pointer-events-none" src="<%= settings.profilePicture %>"/>
        <!-- Color Overlay Image -->
        <img alt="<%= settings.artistName %> Portrait Color" class="color-layer absolute inset-0 w-full h-full object-cover object-top brightness-100 contrast-100 z-10 pointer-events-none" src="<%= settings.profilePicture %>" style="clip-path: circle(0px at 0px 0px);"/>
