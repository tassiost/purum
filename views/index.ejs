<!DOCTYPE html>
<html class="dark" lang="en">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title><%= settings.artistName %> | <%= settings.tagline %></title>
  <link rel="icon" href="data:;base64,iVBORw0KGgo=">
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "outline-variant": "#444748",
            "on-secondary-container": "#b6b5b4",
            "surface-container-high": "#2a2a2a",
            "on-primary": "#2f3131",
            "on-error-container": "#ffdad6",
            "tertiary": "#ffffff",
            "surface": "#131313",
            "on-secondary-fixed": "#1b1c1c",
            "on-secondary": "#303030",
            "primary": "#ffffff",
            "outline": "#8e9192",
            "secondary": "#c8c6c6",
            "primary-container": "#e2e2e2",
            "error-container": "#93000a",
            "on-surface": "#e2e2e2",
            "surface-tint": "#c6c6c7",
            "inverse-surface": "#e2e2e2",
            "on-tertiary-fixed": "#1b1c1c",
            "secondary-fixed": "#e4e2e1",
            "on-primary-fixed": "#1a1c1c",
            "on-background": "#e2e2e2",
            "primary-fixed": "#e2e2e2",
            "surface-container-highest": "#353535",
            "tertiary-fixed": "#e3e2e2",
            "primary-fixed-dim": "#c6c6c7",
            "secondary-container": "#474747",
            "on-primary-container": "#636565",
            "inverse-on-surface": "#303030",
            "on-surface-variant": "#c4c7c8",
            "inverse-primary": "#5d5f5f",
            "on-secondary-fixed-variant": "#474747",
            "surface-dim": "#131313",
            "error": "#ffb4ab",
            "surface-variant": "#353535",
            "on-primary-fixed-variant": "#454747",
            "secondary-fixed-dim": "#c8c6c6",
            "surface-container-lowest": "#0e0e0e",
            "surface-container-low": "#1b1b1b",
            "on-tertiary": "#303031",
            "background": "#131313",
            "surface-container": "#1f1f1f",
            "tertiary-fixed-dim": "#c7c6c6",
            "on-tertiary-fixed-variant": "#464747",
            "surface-bright": "#393939",
            "on-tertiary-container": "#646464",
            "tertiary-container": "#e3e2e2",
            "on-error": "#690005"
          },
          "borderRadius": {
            "DEFAULT": "0.25rem",
            "lg": "0.5rem",
            "xl": "0.75rem",
            "full": "9999px"
          },
          "spacing": {
            "gutter": "32px",
            "margin-mobile": "24px",
            "stack-lg": "32px",
            "section-gap": "120px",
            "stack-md": "16px",
            "margin-desktop": "64px",
            "stack-sm": "8px"
          },
          "fontFamily": {
            "label-md": ["JetBrains Mono"],
            "label-sm": ["JetBrains Mono"],
            "headline-xl": ["Hanken Grotesk"],
            "body-lg": ["Hanken Grotesk"],
            "headline-lg-mobile": ["Hanken Grotesk"],
            "headline-lg": ["Hanken Grotesk"],
            "body-md": ["Hanken Grotesk"]
          },
          "fontSize": {
            "label-md": ["14px", {"lineHeight": "20px", "letterSpacing": "0.1em", "fontWeight": "500"}],
            "label-sm": ["12px", {"lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "400"}],
            "headline-xl": ["80px", {"lineHeight": "88px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
            "body-lg": ["18px", {"lineHeight": "28px", "letterSpacing": "0em", "fontWeight": "400"}],
            "headline-lg-mobile": ["32px", {"lineHeight": "36px", "letterSpacing": "0.05em", "fontWeight": "600"}],
            "headline-lg": ["48px", {"lineHeight": "52px", "letterSpacing": "0.05em", "fontWeight": "600"}],
            "body-md": ["16px", {"lineHeight": "24px", "letterSpacing": "0em", "fontWeight": "400"}]
          }
        },
      },
    }
  </script>
  <style>
    body {
      background-color: #000000;
      color: #ffffff;
      cursor: crosshair;
    }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .grain-overlay {
      pointer-events: none;
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.80' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
      opacity: 0.05;
      z-index: 9999;
    }
    .reveal-text {
      clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
      transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .glitch-hover:hover {
      text-shadow: 2px 0 #ff0000, -2px 0 #00ffff;
    }
    .asymmetric-image-container {
      clip-path: polygon(0 0, 100% 2%, 100% 98%, 0% 100%);
    }
    iframe {
      filter: grayscale(1) contrast(1.2);
    }
  </style>
</head>
<body class="antialiased overflow-x-hidden">
  <div class="grain-overlay"></div>
  
  <!-- Top Navigation Shell -->
  <nav class="flex justify-between items-center px-margin-desktop h-24 w-full z-50 bg-surface fixed top-0 border-b border-outline-variant">
    <div class="flex items-center">
      <% if (settings.logoUrl) { %>
        <img referrerpolicy="no-referrer" alt="<%= settings.artistName %> Logo" class="h-12 w-auto object-contain" src="<%= settings.logoUrl %>"/>
      <% } else { %>
        <span class="font-headline-lg text-[20px] font-bold uppercase tracking-widest"><%= settings.artistName %></span>
      <% } %>
    </div>
    
    <!-- Desktop Nav -->
    <div class="hidden md:flex gap-margin-mobile items-center">
      <a class="font-label-md text-label-md uppercase tracking-widest text-primary border-b border-primary pb-1" href="#home">HOME</a>
      <a class="font-label-md text-label-md uppercase tracking-widest text-outline hover:text-primary transition-none" href="#about">ABOUT</a>
      <a class="font-label-md text-label-md uppercase tracking-widest text-outline hover:text-primary transition-none" href="#archives">ARCHIVES</a>
      <a class="font-label-md text-label-md uppercase tracking-widest text-outline hover:text-primary transition-none" href="#audio">AUDIO</a>
      <% if (user) { %>
        <a class="ml-stack-lg border border-primary px-stack-md py-stack-sm font-label-md text-label-md hover:bg-primary hover:text-on-primary transition-none flex items-center justify-center" href="/admin/dashboard">ADMIN</a>
      <% } else { %>
        <a class="ml-stack-lg border border-primary px-stack-md py-stack-sm font-label-md text-label-md hover:bg-primary hover:text-on-primary transition-none flex items-center justify-center" href="/admin/login">LOGIN</a>
      <% } %>
    </div>
    
    <!-- Mobile Menu Trigger -->
    <button class="md:hidden text-primary" onclick="toggleMobileMenu()">
      <span class="material-symbols-outlined">menu</span>
    </button>
  </nav>

  <!-- Mobile Nav Dropdown -->
  <div id="mobile-menu" class="hidden fixed top-24 left-0 w-full bg-surface border-b border-outline-variant z-40 flex flex-col p-6 gap-4 md:hidden">
    <a class="font-label-md text-label-md uppercase text-primary" href="#home" onclick="toggleMobileMenu()">HOME</a>
    <a class="font-label-md text-label-md uppercase text-outline" href="#about" onclick="toggleMobileMenu()">ABOUT</a>
    <a class="font-label-md text-label-md uppercase text-outline" href="#archives" onclick="toggleMobileMenu()">ARCHIVES</a>
    <a class="font-label-md text-label-md uppercase text-outline" href="#audio" onclick="toggleMobileMenu()">AUDIO</a>
    <% if (user) { %>
      <a class="border border-primary px-stack-md py-stack-sm font-label-md text-label-md text-center" href="/admin/dashboard" onclick="toggleMobileMenu()">ADMIN</a>
    <% } else { %>
      <a class="border border-primary px-stack-md py-stack-sm font-label-md text-label-md text-center" href="/admin/login" onclick="toggleMobileMenu()">LOGIN</a>
    <% } %>
  </div>

  <main class="mt-24">
    <!-- Hero Section -->
    <section class="grid grid-cols-12 min-h-[90vh] px-margin-desktop items-center gap-gutter" id="home">
      <div class="col-span-12 lg:col-span-6 flex flex-col justify-center order-2 lg:order-1 py-stack-lg">
        <div class="overflow-hidden">
          <h1 class="font-headline-xl text-headline-xl uppercase tracking-tighter reveal-text"><%= settings.artistName %></h1>
        </div>
        <div class="mt-stack-lg max-w-md">
          <div class="mb-stack-md flex items-center gap-2 border border-outline-variant/30 w-fit px-2 py-1 bg-surface-container-low">
            <span class="font-label-sm text-[10px] text-primary">LABEL / AFFILIATION:</span>
            <span class="font-label-sm text-[10px] text-outline uppercase"><%= settings.affiliation %></span>
          </div>
          <h2 class="font-label-md text-label-md uppercase tracking-[0.3em] mb-stack-md text-outline"><%= settings.location %></h2>
          <p class="font-body-lg text-body-lg text-secondary border-l border-outline-variant pl-stack-md py-stack-sm mb-stack-lg">
            <%= settings.tagline %>
          </p>
          <p class="font-label-sm text-label-sm text-outline-variant mb-stack-lg italic leading-tight"><%= settings.subTagline %></p>
          <div class="flex flex-col gap-4">
            <a class="font-label-md text-label-md text-primary tracking-[0.2em] hover:tracking-[0.3em] transition-all duration-300" href="mailto:<%= settings.contactEmail %>">BOOKING: <%= settings.contactEmail.toUpperCase() %> ———</a>
            <div class="mt-4 border-t border-outline-variant pt-2 flex items-center justify-between">
              <span class="font-label-sm text-label-sm text-outline uppercase tracking-widest">SOCIAL_NODE_STATUS</span>
              <span class="font-label-sm text-label-sm text-primary font-bold"><%= settings.followers %></span>
            </div>
            <a class="font-label-md text-label-md text-outline tracking-[0.2em] hover:text-primary transition-colors" href="#audio">LISTEN_TRANSMISSIONS //</a>
          </div>
        </div>
      </div>
      <div class="col-span-12 lg:col-span-6 relative order-1 lg:order-2 h-[60vh] lg:h-[80vh]">
        <div class="absolute inset-0 bg-outline-variant/10 -rotate-1 scale-105 z-0"></div>
        <img alt="<%= settings.artistName %> Portrait" class="w-full h-full object-cover object-top grayscale brightness-90 contrast-110 z-10 relative asymmetric-image-container border border-outline-variant" src="<%= settings.profilePicture %>"/>
      </div>
    </section>

    <!-- About Section -->
    <section class="px-margin-desktop py-section-gap border-t border-outline-variant" id="about">
      <div class="grid grid-cols-1 gap-gutter items-start lg:grid-cols-2">
        <div class="lg:col-span-1">
          <h3 class="font-headline-lg text-headline-lg uppercase tracking-tight leading-none mb-stack-lg text-primary font-bold">PROJECT_MANIFESTO //</h3>
        </div>
        <div class="lg:col-span-1">
          <p class="font-body-lg text-body-lg text-on-surface leading-relaxed max-w-3xl border-l-2 border-primary pl-6">
            <%= settings.biography %>
          </p>
          <p class="font-body-lg text-body-lg text-secondary mt-stack-md leading-relaxed max-w-3xl">
            <%= settings.artistStatement %>
          </p>
        </div>
      </div>
    </section>

    <!-- System Archives (Gallery) -->
    <section class="px-margin-desktop py-section-gap bg-surface-container-lowest border-t border-b border-outline-variant" id="archives">
      <div class="flex justify-between items-end border-b border-outline-variant pb-stack-md mb-stack-lg">
        <h3 class="font-headline-lg text-headline-lg uppercase tracking-tight">SYSTEM ARCHIVES</h3>
        <span class="font-label-md text-label-md text-outline">VINTAGE_CULTURE_SYS_042</span>
      </div>
      <div class="grid grid-cols-2 gap-4 md:grid-cols-3">
        <% artworks.forEach(art => { %>
          <div class="aspect-[2/3] overflow-hidden border border-outline-variant group relative">
            <a href="/project/<%= art.id %>" class="block w-full h-full">
              <img alt="<%= art.title %>" class="w-full h-full object-cover grayscale brightness-75 hover:scale-105 hover:brightness-100 transition-all duration-700" src="<%= art.imageUrl %>"/>
              <div class="absolute bottom-0 left-0 right-0 bg-black/90 p-4 opacity-0 group-hover:opacity-100 transition-opacity border-t border-outline-variant">
                <p class="font-label-sm text-[11px] text-primary uppercase font-bold tracking-wider"><%= art.title %></p>
                <p class="font-label-sm text-[9px] text-outline uppercase mt-1"><%= art.category %></p>
              </div>
            </a>
          </div>
        <% }); %>
      </div>
    </section>

    <!-- Audio Transmissions Section -->
    <section class="px-margin-desktop py-section-gap border-t border-outline-variant" id="audio">
      <div class="flex flex-col md:flex-row justify-between items-end border-b border-outline-variant pb-stack-md mb-stack-lg">
        <h3 class="font-headline-lg text-headline-lg uppercase tracking-tight">Transmissions / Audio</h3>
        <span class="font-label-md text-label-md text-outline">STREAM_LINK_STABLE</span>
      </div>
      <!-- SoundCloud Embed Container (Dedicated Full Width) -->
      <div class="w-full bg-surface-container-low border border-outline-variant p-4 grayscale contrast-125">
        <iframe allow="autoplay; encrypted-media" class="grayscale contrast-125 invert" frameborder="no" height="380" scrolling="no" src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/purumofficial&amp;color=%23000000&amp;auto_play=false&amp;hide_related=false&amp;show_comments=true&amp;show_user=true&amp;show_reposts=false&amp;show_teaser=true&amp;visual=true" width="100%"></iframe>
      </div>
    </section>

    <!-- Affiliation & Events Section -->
    <section class="px-margin-desktop py-section-gap border-t border-outline-variant" id="events">
      <div class="flex flex-col md:flex-row justify-between items-end border-b border-outline-variant pb-stack-md mb-stack-lg">
        <h3 class="font-headline-lg text-headline-lg uppercase tracking-tight">Label &amp; Events</h3>
        <span class="font-label-md text-label-md text-outline">YAKU.RECORDS_SYS</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter mt-8">
        <!-- Label Info Card -->
        <div class="border border-outline-variant p-stack-lg bg-surface-container-low flex flex-col justify-between min-h-[220px]">
          <div>
            <div class="flex justify-between items-center mb-stack-md">
              <span class="font-label-sm text-label-sm text-primary uppercase tracking-widest">AFFILIATION</span>
              <span class="material-symbols-outlined">public</span>
            </div>
            <h4 class="font-headline-lg text-[24px] mb-stack-sm leading-tight">YAKU RECORDS</h4>
            <p class="font-body-md text-body-md text-secondary opacity-80 leading-relaxed">
              Bern-based House &amp; Techno Event Label. Representing underground groove and raw chaotic energy.
            </p>
          </div>
          <div class="mt-4 pt-2 border-t border-outline-variant/30 flex justify-between items-center">
            <span class="font-label-sm text-label-sm text-outline uppercase">FOLLOWER_NODE_STATS</span>
            <span class="font-label-sm text-label-sm text-primary font-bold">1,500_FOLLOWERS</span>
          </div>
        </div>
        <!-- Upcoming Event Card -->
        <div class="border border-primary p-stack-lg bg-surface-container-low flex flex-col justify-between min-h-[220px]">
          <div>
            <div class="flex justify-between items-center mb-stack-md">
              <span class="font-label-sm text-label-sm text-primary uppercase tracking-widest">UPCOMING_EVENT</span>
              <span class="material-symbols-outlined">event_upcoming</span>
            </div>
            <h4 class="font-headline-lg text-[24px] mb-stack-sm leading-tight text-primary">BLUE DIMENSION @ 14.03.25</h4>
            <p class="font-body-md text-body-md text-secondary opacity-80 leading-relaxed">
              Featuring @blue.dimension.djs. High-intensity sound transmission and hypnotic groove loops.
            </p>
          </div>
          <div class="mt-4 pt-2 border-t border-outline-variant/30 flex justify-between items-center">
            <span class="font-label-sm text-label-sm text-outline uppercase">EVENT_STATUS</span>
            <span class="font-label-sm text-label-sm text-primary font-bold">STABLE_TRANSMISSION</span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer Shell -->
  <footer class="flex flex-col md:flex-row justify-between items-center px-margin-desktop py-stack-lg mt-section-gap w-full border-t border-outline-variant bg-surface">
    <div class="flex flex-col gap-stack-sm mb-stack-lg md:mb-0">
      <span class="font-label-md text-label-md text-primary uppercase tracking-widest">MONOLITH INDUSTRIAL SYSTEMS</span>
      <p class="font-label-sm text-label-sm text-outline">©<%= new Date().getFullYear() %> <%= settings.artistName %>. ALL RIGHTS RESERVED.</p>
    </div>
    <div class="flex gap-margin-mobile">
      <a class="font-label-sm text-label-sm text-outline hover:text-primary transition-colors" href="#">PRIVACY</a>
      <a class="font-label-sm text-label-sm text-outline hover:text-primary transition-colors" href="#">IMPRINT</a>
      <a class="font-label-sm text-label-sm text-outline hover:text-primary transition-colors" href="mailto:<%= settings.contactEmail %>">CONTACT</a>
    </div>
    <div class="flex gap-stack-md mt-stack-lg md:mt-0">
      <% if (settings.instagram) { %>
        <a class="w-10 h-10 border border-outline-variant flex items-center justify-center hover:bg-primary hover:text-on-primary transition-none" href="https://instagram.com/<%= settings.instagram %>" target="_blank" rel="noopener noreferrer">
          <span class="material-symbols-outlined text-[18px]">share</span>
        </a>
      <% } %>
      <% if (settings.github) { %>
        <a class="w-10 h-10 border border-outline-variant flex items-center justify-center hover:bg-primary hover:text-on-primary transition-none" href="https://github.com/<%= settings.github %>" target="_blank" rel="noopener noreferrer">
          <span class="material-symbols-outlined text-[18px]">public</span>
        </a>
      <% } %>
    </div>
  </footer>

  <!-- Cookie Consent Placeholder -->
  <div class="fixed bottom-margin-mobile right-margin-mobile z-[100] max-w-xs bg-surface-container-highest border border-outline-variant p-stack-md shadow-2xl transition-all duration-500" id="cookie-consent">
    <p class="font-body-md text-body-md text-on-surface mb-stack-md">PURUM uses cookies to ensure structural integrity and experience tracking.</p>
    <button class="w-full bg-primary text-on-primary py-stack-sm font-label-md text-label-md uppercase" onclick="this.closest('#cookie-consent').style.display='none'">
      ACKNOWLEDGE
    </button>
  </div>

  <script>
    // Atmospheric effects
    window.addEventListener('load', () => {
      setTimeout(() => {
        const consent = document.getElementById('cookie-consent');
        if (consent) {
          consent.classList.remove('opacity-0', 'translate-y-4');
        }
      }, 2000);

      // Subtle parallax on images
      window.addEventListener('scroll', () => {
        const scrolled = window.pageYOffset;
        const images = document.querySelectorAll('img');
        images.forEach(img => {
          const speed = 0.05;
          if(img.closest('.asymmetric-image-container')) {
            img.style.transform = `translateY(${scrolled * speed}px)`;
          }
        });
      });
    });

    // Instant click simulation
    document.querySelectorAll('a, button').forEach(el => {
      el.addEventListener('mousedown', () => {
        el.style.opacity = '0.7';
      });
      el.addEventListener('mouseup', () => {
        el.style.opacity = '1';
      });
    });

    // Mobile menu toggle
    function toggleMobileMenu() {
      const menu = document.getElementById('mobile-menu');
      if (menu) {
        menu.classList.toggle('hidden');
      }
    }
  </script>
</body>
</html>
